# ============================================================
#  Secure File Transfer System — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# Default admin password — CHANGE BEFORE FIRST RUN
ADMIN_PASSWORD=Admin@1234

# Database paths
AUTH_DB_PATH=users.db
AUDIT_DB_PATH=audit.db

# Log file path
AUDIT_LOG_PATH=logs/audit.log

# File storage directories
UPLOAD_DIR=uploads
DOWNLOAD_DIR=downloads

# Chunk size in MB (default 10)
CHUNK_SIZE_MB=10

# Session TTL in seconds (default 3600 = 1 hour)
SESSION_TTL=3600
